# ============================================================================
# miman — LetA deployment profile env contract (spec 03-M §9.3)
# ============================================================================
# cp .env.example .env, then fill in every value below. This file is
# git-ignored once copied to .env — never commit real secrets.
# ============================================================================

# store selection — deploy-check enforces qdrant in this profile
MEM0_VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=<class>_<env>_<consumer>_memory_<embedder>_v1
# Required by this deploy profile even though qdrant has no host ports (see
# docker-compose.yml comment) — generate with: openssl rand -base64 32
QDRANT_API_KEY=
QDRANT_EMBEDDING_MODEL_DIMS=1536
QDRANT_ON_DISK=false

# auth — hard requirements in non-local
AUTH_DISABLED=false
JWT_SECRET=<openssl rand -base64 48>
ADMIN_API_KEY=<long-random; admin plane only>

# app DB (auth, request logs, entities, migrations — required even in qdrant mode)
# POSTGRES_HOST/POSTGRES_PORT are pinned in docker-compose.yml (must match the
# appdb service) and are not read from this file — listed for the record.
POSTGRES_HOST=appdb
POSTGRES_PORT=5432
POSTGRES_DB=miman_app
POSTGRES_USER=miman
POSTGRES_PASSWORD=<long-random>

# LLM + embedder (OpenRouter via core env fallback — spec §3.2)
OPENAI_API_KEY=<openrouter key>
OPENAI_BASE_URL=https://openrouter.ai/api/v1
MEM0_DEFAULT_LLM_MODEL=openai/gpt-5-mini
MEM0_DEFAULT_EMBEDDER_MODEL=openai/text-embedding-3-small

# hygiene
MEM0_TELEMETRY=false
REQUEST_LOG_RETENTION_DAYS=30
HISTORY_DB_PATH=/app/history/history.db
MIMAN_ENV=prod

# Image tag built/pulled by docker-compose.yml (make miman-docker-build VERSION=X.Y.Z)
IMAGE_VERSION=dev-local
IMAGE_REVISION=dev-local
